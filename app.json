{
  "expo": {
    "name": " ",
    "slug": "parkifyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/car-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/car-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "splash": {
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/Parkify.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
